<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">
 
  <appender name="CONSOLA" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{30} - %msg%n</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>
 
  <!-- Karate: INFO muestra resumen de escenarios sin inundar con cada byte HTTP -->
  <logger name="com.intuit.karate"          level="INFO"  additivity="false">
    <appender-ref ref="CONSOLA"/>
  </logger>
 
  <!-- Silencia librerías de transporte que no aportan al diagnóstico funcional -->
  <logger name="org.apache.http"            level="WARN"/>
  <logger name="javax.net.ssl"              level="WARN"/>
  <logger name="org.springframework"        level="WARN"/>
 
  <root level="WARN">
    <appender-ref ref="CONSOLA"/>
  </root>
 
</configuration>